{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "jakeayy-xyz",
    "main": "./.cloudflare/worker.js",
    "placement": {
        "mode": "smart"
    },
    "workers_dev": false,
    "preview_urls": false,
    "site": {
            "bucket": "./.cloudflare/public"
    },
    "build": {
            "command": "bun run build"
    },
    "compatibility_date": "2026-02-19",
    "compatibility_flags": [ "nodejs_compat" ]
}